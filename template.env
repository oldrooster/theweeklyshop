# Copy this file to .env.local and fill in your values
# cp template.env .env.local

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
# Required if using Claude for receipt import or recipe generation
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Vertex AI ──────────────────────────────────────────────────────────
# Required if using Vertex AI (Gemini) for receipt import or recipe generation
#
# GOOGLE_VERTEX_SA_KEY: the full contents of a service account JSON key file,
# on a single line. Create one at:
#   GCP Console → IAM & Admin → Service Accounts → Keys → Add Key → JSON
# The service account needs the "Vertex AI User" role.
GOOGLE_VERTEX_SA_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# GOOGLE_CLOUD_PROJECT: fallback project ID used if you haven't set one in the
# Settings UI. Optional if the project is already in the service account JSON.
GOOGLE_CLOUD_PROJECT=my-gcp-project
